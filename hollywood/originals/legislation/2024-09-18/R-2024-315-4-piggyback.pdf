        window.name = "MasterWindow";
        var first = true;
        var first2 = true;
        function OpenTelerikWindow(url) {
            var w = radopen(url, 'RadWindow1');
            w.add_pageLoad(function () {
                focusRadWindow(w);
            });

            if (first) {
                //w.togglePin(); 
                first = false;
            }
        }
        function OpenTelerikWindow2(url) {
            var w = radopen(url, 'RadWindow2')
